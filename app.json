{
  "expo": {
    "name": "Essencial 3",
    "slug": "essencial3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.renanbarretoj.essencial3",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "O Essencial 3 usa notificações para te lembrar das suas 3 prioridades do dia.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#F2F2F7"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#007AFF"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "O Essencial 3 usa o microfone para você ditar suas prioridades por voz.",
          "speechRecognitionPermission": "O Essencial 3 usa reconhecimento de voz para converter suas prioridades faladas em texto."
        }
      ]
    ],
    "scheme": "essencial3",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "19f6d92a-58b3-412b-aaff-e6a66b9143ac"
      }
    }
  }
}
